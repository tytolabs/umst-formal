# ── Rust build artifacts ─────────────────────────────────────────────────────
target/
# Cargo.lock IS tracked at the workspace root for reproducible builds.
# (Only pure-library crates without binaries conventionally omit Cargo.lock.)

# ── Haskell build artifacts ───────────────────────────────────────────────────
dist/
dist-newstyle/
*.hi
*.dyn_hi
*.dyn_o
cabal.project.local

# ── Agda build artifacts ──────────────────────────────────────────────────────
*.agdai
# NOTE: *.agda-lib files are hand-written project descriptors; do NOT ignore them.
Agda/html/

# ── Coq build artifacts ───────────────────────────────────────────────────────
*.vo
*.vos
*.vok
*.glob
*.aux
# CoqMakefile and its config are generated by coq_makefile; do not commit.
Coq/CoqMakefile
Coq/CoqMakefile.conf
Coq/html/
Coq/ocaml/
Coq/.coq-native/
# Coq dependency and tactic-cache files (generated at build time)
Coq/.CoqMakefile.d
Coq/.nia.cache
# OCaml modules produced by `coqc Extraction.v` (regenerate locally)
Coq/gate_extracted.ml
Coq/gate_extracted.mli

# ── Lean 4 build artifacts ───────────────────────────────────────────────────
# Lake build cache (.lake/build/, .lake/packages/)
.lake/
# Compiled Lean objects
*.olean
*.ilean
# Lake manifest is generated; lake-manifest.json is intentionally committed
# for reproducible builds, so do NOT add it here.

# ── OCaml build artifacts ────────────────────────────────────────────────────
*.cmi
*.cmo
*.cmx
*.cma
*.cmxa

# ── Editor / OS artifacts ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tmp
*.log
